# Copy to .env and fill in your values. Never commit .env to git.

# Google APIs (Places + Maps)
# Get key from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New), Maps SDK for Android
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Google OAuth (same Client ID as Supabase → Authentication → Google provider)
# Used for "Import contacts from Google" on All Friends circle
EXPO_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# Gemini API (From Poster AI feature)
# Get key from: https://aistudio.google.com/apikey
EXPO_PUBLIC_GEMINI_API_KEY=
